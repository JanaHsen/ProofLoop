# ProofLoop environment — copy to .env (gitignored) and fill in real local values.
#
# Secrets-by-layer rule:
#   - .env          local developer machine only, gitignored, never committed
#   - .env.example  THIS file: dummy values, committed as documentation
#   - CI            GitHub Actions encrypted secrets (Phase 6)
# Nothing is ever hardcoded in source.

# ---------------------------------------------------------------------------
# Platform (the tester)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME    # used from Phase 2; NOT needed to run the app in Phase 0
BASE_URL=http://localhost:3000         # the ONLY thing the tester is told about the SUT (black-box boundary)
PROOFLOOP_VERIFIER_MODEL=claude-opus-4-8  # Phase 3 outcome verifier; separately configurable from the decider. Provisional default selected at the Task 4 model-selection gate (15/15 on the replay set); override per env. Must be priced in platform/config/pricing.<id>.json before a live verify run.
PROOFLOOP_SUMMARY_MODEL=                # Phase 4 OPTIONAL AI summary model. Required ONLY when `npm run report -- ... --summary` is used; has NO silent default. Plain report generation makes no LLM call. Must be priced in platform/config/pricing.<id>.json or the summary fails open (deterministic report still written). e.g. claude-sonnet-4-6

# ---------------------------------------------------------------------------
# App under test (the SUT)
# ---------------------------------------------------------------------------
APP_PORT=3000                          # port the SUT serves on
SESSION_SECRET=dev-only-not-a-real-secret   # real server-side session signing key; replace locally
PROOFLOOP_BUGS=                        # comma-separated toggle flags, e.g. BUG-001,MUT-002
                                       # empty = CLEAN state (all flows correct)
PROOFLOOP_DEBUG_TOKEN=debug-only-dummy-token   # required for /debug/* routes; unset disables them; harness-only — the engine never sends it
