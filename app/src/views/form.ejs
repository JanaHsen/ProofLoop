<%- include("partials/head", { title: "Validated form" }) %>
  <h1>Submit a request</h1>
  <% if (submitted) { %>
    <p class="success" role="status">
      Request received for <strong><%= values.name %></strong>
      (<%= values.email %>) — amount <%= values.amount %>.
    </p>
  <% } %>
  <form method="post" action="/form" class="stacked" novalidate>
    <label>
      Name
      <input type="text" name="name" value="<%= values.name %>" />
      <% if (errors.name) { %><span class="error"><%= errors.name %></span><% } %>
    </label>
    <label>
      Email
      <input type="text" name="email" value="<%= values.email %>" />
      <% if (errors.email) { %><span class="error"><%= errors.email %></span><% } %>
    </label>
    <label>
      Amount
      <input type="text" name="amount" value="<%= values.amount %>" />
      <% if (errors.amount) { %><span class="error"><%= errors.amount %></span><% } %>
    </label>
    <button type="submit">Submit</button>
  </form>
<%- include("partials/foot") %>
