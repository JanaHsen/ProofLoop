<%- include("partials/head", { title: "Log in" }) %>
  <h1>Log in</h1>
  <% if (error) { %>
    <p class="error" role="alert"><%= error %></p>
  <% } %>
  <form method="post" action="/login" class="stacked">
    <label>
      Username
      <input type="text" name="<%= activeBugs.includes("MUT-002") ? "user_name" : "username" %>" id="<%= activeBugs.includes("MUT-002") ? "user_name" : "username" %>" autocomplete="username" required value="<%= username %>" />
    </label>
    <label>
      Password
      <input type="password" name="password" autocomplete="current-password" required />
    </label>
    <input type="hidden" name="next" value="<%= next %>" />
    <button type="submit">Log in</button>
  </form>
  <p class="hint">Try <code>alice / password123</code> or <code>bob / hunter2</code>.</p>
<%- include("partials/foot") %>
