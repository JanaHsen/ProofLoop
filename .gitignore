# Dependencies
node_modules/

# Env & secrets — NEVER commit real secrets. Only .env.example is committed.
.env
.env.local
*.local

# Build output
dist/
build/
.next/
out/

# Run artifacts (logs, traces, videos, reports) — generated, not source
# platform/runs/ holds generated run subdirectories (one per runId). Ignore its
# generated contents, but keep the committed .gitkeep + README.md tracked. (Scope the
# pattern to the dir's contents — a bare `runs/` would exclude the directory itself,
# and Git can't re-include a file whose parent dir is excluded.)
/platform/runs/*
!/platform/runs/.gitkeep
!/platform/runs/README.md
artifacts/
*.log
playwright-report/
test-results/
trace.zip
*.webm

# OS / editor cruft
.DS_Store
Thumbs.db
